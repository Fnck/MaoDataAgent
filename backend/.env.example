# ============================================================================
# DataAgent Backend — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All values here override the defaults in conf.yml.
# Variables already set in your shell environment take precedence over .env.
# ============================================================================

# --- LLM Configuration ---
# Base URL of the OpenAI-compatible API
LLM_API_BASE=https://api.openai.com/v1
# Your API key for the LLM provider
LLM_API_KEY=sk-xxxx
# Model name to use for chat completions
LLM_MODEL=gpt-4o-mini

# --- Embedding Configuration ---
# Base URL of the embedding API (defaults to same as LLM if not set)
EMBEDDING_API_BASE=https://api.openai.com/v1
# API key for the embedding provider
EMBEDDING_API_KEY=sk-xxxx
# Embedding model name
EMBEDDING_MODEL=text-embedding-3-small

# --- Authentication ---
# Secret key for JWT token signing. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-in-production
# JWT token expiration time in hours
TOKEN_EXPIRE_HOURS=24

# --- Object Storage (optional, for file-based data sources) ---
OS_ENDPOINT=
OS_REGION=
OS_ACCESS_KEY=your-access-key
OS_SECRET_KEY=your-secret-key
OS_BUCKET=dataagent

# --- Workflow ---
# Agent mode: "none" | "dynamic" | "yaml"
WORKFLOW_MODE=none
# Maximum iterations for the dynamic agent loop
WORKFLOW_MAX_ITERATIONS=10

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL connection (used by Docker Compose; overrides alembic.ini default)
# Example: postgresql+asyncpg://user:password@postgres:5432/dbname
DATABASE_URL=
